# Copia a .env.local y rellena tu token (gratis):
# https://www.football-data.org/client/register

FOOTBALL_DATA_API_KEY=

# Obligatorio en Vercel para el cron de resultados live (/api/cron/sync-live)
# Genera uno aleatorio: openssl rand -hex 32
CRON_SECRET=

# Opcional — solo si quieres parches manuales desde GitHub (quiniela MVP, etc.)
# LIVE_DATA_URL=

# Opcional — rango de fechas para la API live (por defecto 2026-06-11 → hoy+2)
# WC_LIVE_DATE_FROM=2026-06-11
# WC_LIVE_DATE_TO=2026-07-20
